# OS
.DS_Store

# Generated figures (regenerate with scripts/figures/make_paper_figures.py)
figures/*.pdf

# Raw/intermediate data — not shipped. Raw prices and raw third-party text are
# not redistributable (see DATA-STATEMENTS.md); intermediates are regenerable.
# The derived-feature deposit data/processed/ IS committed (licensing-clean
# layer, covered by MANIFEST.sha256) and is additionally DOI-archived on
# acceptance; see data/README.md for layout and build order.
data/external/
data/interim/
data/raw/prices/
